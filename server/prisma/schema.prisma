generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  items     Item[]
  createdAt DateTime @default(now())
}

model Item {
  id         Int         @id @default(autoincrement())
  name       String
  price      Float
  categoryId Int
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  active     Boolean     @default(true)
  department String      @default("KITCHEN")
  cost       ItemCost?
  createdAt  DateTime    @default(now())
}

model Waiter {
  id        Int      @id @default(autoincrement())
  name      String
  pin       String
  active    Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
}

model Order {
  id          Int         @id @default(autoincrement())
  number      Int         @unique
  status      OrderStatus @default(OPEN)
  tableNumber String?
  comment     String?
  items       OrderItem[]
  total       Float
  paymentType PaymentType @default(CASH)
  waiterId    Int?
  waiter      Waiter?     @relation(fields: [waiterId], references: [id])
  waiterName  String?
  createdAt   DateTime    @default(now())
  closedAt    DateTime?
}

model OrderItem {
  id       Int   @id @default(autoincrement())
  orderId  Int
  itemId   Int
  order    Order @relation(fields: [orderId], references: [id])
  item     Item  @relation(fields: [itemId], references: [id])
  quantity Int
  price    Float
  name     String
}

// ─── БУХГАЛТЕРИЯ ─────────────────────────────────────────────

model Expense {
  id          Int             @id @default(autoincrement())
  amount      Float
  category    ExpenseCategory
  description String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
}

model Debt {
  id          Int        @id @default(autoincrement())
  clientName  String
  phone       String?
  amount      Float
  description String?
  status      DebtStatus @default(UNPAID)
  createdAt   DateTime   @default(now())
  paidAt      DateTime?
}

model Revision {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  cashIn    Float    @default(0)
  cashOut   Float    @default(0)
  cardTotal Float    @default(0)
  expenses  Float    @default(0)
  notes     String?
  createdBy String?
  createdAt DateTime @default(now())
}

model AccountingUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

// ─── СКЛАД ────────────────────────────────────────────────────

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String?
  active    Boolean   @default(true)
  arrivals  StockArrival[]
  createdAt DateTime  @default(now())
}

model StockProduct {
  id            Int              @id @default(autoincrement())
  name          String
  unit          String           @default("шт")
  costPrice     Float            @default(0)
  currentStock  Float            @default(0)
  minStock      Float            @default(0)
  department    String           @default("KITCHEN")
  active        Boolean          @default(true)
  arrivalItems  StockArrivalItem[]
  writeoffItems StockWriteoffItem[]
  inventoryItems InventoryItem[]
  createdAt     DateTime         @default(now())
}

model StockArrival {
  id          Int                @id @default(autoincrement())
  date        DateTime           @default(now())
  supplierId  Int?
  supplier    Supplier?          @relation(fields: [supplierId], references: [id])
  invoiceNum  String?
  totalAmount Float              @default(0)
  notes       String?
  createdBy   String?
  items       StockArrivalItem[]
  createdAt   DateTime           @default(now())
}

model StockArrivalItem {
  id         Int          @id @default(autoincrement())
  arrivalId  Int
  arrival    StockArrival @relation(fields: [arrivalId], references: [id], onDelete: Cascade)
  productId  Int
  product    StockProduct @relation(fields: [productId], references: [id])
  quantity   Float
  price      Float
  total      Float
}

model StockWriteoff {
  id        Int                @id @default(autoincrement())
  date      DateTime           @default(now())
  reason    String?
  notes     String?
  createdBy String?
  items     StockWriteoffItem[]
  createdAt DateTime           @default(now())
}

model StockWriteoffItem {
  id          Int           @id @default(autoincrement())
  writeoffId  Int
  writeoff    StockWriteoff @relation(fields: [writeoffId], references: [id], onDelete: Cascade)
  productId   Int
  product     StockProduct  @relation(fields: [productId], references: [id])
  quantity    Float
  reason      String?
}

model Inventory {
  id        Int             @id @default(autoincrement())
  date      DateTime        @default(now())
  notes     String?
  createdBy String?
  items     InventoryItem[]
  createdAt DateTime        @default(now())
}

model InventoryItem {
  id          Int          @id @default(autoincrement())
  inventoryId Int
  inventory   Inventory    @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  productId   Int
  product     StockProduct @relation(fields: [productId], references: [id])
  expected    Float
  actual      Float
  diff        Float
}

// ─── КОНТРОЛЬ ЦЕН ─────────────────────────────────────────────

model ItemCost {
  id        Int      @id @default(autoincrement())
  itemId    Int      @unique
  item      Item     @relation(fields: [itemId], references: [id])
  costPrice Float    @default(0)
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  OPEN
  PENDING
  ACCEPTED
  PAID
  CANCELLED
}

enum PaymentType {
  CASH
  CARD
}

enum ExpenseCategory {
  PURCHASE
  SALARY
  RENT
  UTILITIES
  MARKETING
  REPAIR
  OTHER
}

enum DebtStatus {
  UNPAID
  PAID
}
