generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  items     Item[]
  createdAt DateTime @default(now())
}

model Item {
  id         Int         @id @default(autoincrement())
  name       String
  price      Float
  categoryId Int
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
}

model Waiter {
  id        Int      @id @default(autoincrement())
  name      String
  pin       String
  active    Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
}

model Order {
  id          Int         @id @default(autoincrement())
  number      Int         @unique
  status      OrderStatus @default(OPEN)
  tableNumber String?
  comment     String?
  items       OrderItem[]
  total       Float
  paymentType PaymentType @default(CASH)
  waiterId    Int?
  waiter      Waiter?     @relation(fields: [waiterId], references: [id])
  waiterName  String?
  createdAt   DateTime    @default(now())
  closedAt    DateTime?
}

model OrderItem {
  id       Int   @id @default(autoincrement())
  orderId  Int
  itemId   Int
  order    Order @relation(fields: [orderId], references: [id])
  item     Item  @relation(fields: [itemId], references: [id])
  quantity Int
  price    Float
  name     String
}

// ─── БУХГАЛТЕРИЯ ─────────────────────────────────────────────

model Expense {
  id          Int             @id @default(autoincrement())
  amount      Float
  category    ExpenseCategory
  description String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
}

model Debt {
  id          Int        @id @default(autoincrement())
  clientName  String
  phone       String?
  amount      Float
  description String?
  status      DebtStatus @default(UNPAID)
  createdAt   DateTime   @default(now())
  paidAt      DateTime?
}

model Revision {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  cashIn    Float    @default(0)
  cashOut   Float    @default(0)
  cardTotal Float    @default(0)
  expenses  Float    @default(0)
  notes     String?
  createdBy String?
  createdAt DateTime @default(now())
}

model AccountingUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

enum OrderStatus {
  OPEN
  PENDING
  ACCEPTED
  PAID
  CANCELLED
}

enum PaymentType {
  CASH
  CARD
}

enum ExpenseCategory {
  PURCHASE
  SALARY
  RENT
  UTILITIES
  MARKETING
  REPAIR
  OTHER
}

enum DebtStatus {
  UNPAID
  PAID
}
