{
  "name": "cafe-pos-desktop",
  "version": "1.0.0",
  "description": "Кассовая программа для кафе",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "prisma": "^5.10.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.cafe.pos",
    "productName": "ЛаунжКасса",
    "copyright": "Кафе-касса",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "!node_modules/prisma/engines/**",
      "node_modules/**",
      "server/**",
      "public/**"
    ],
    "extraResources": [
      {
        "from": "../server",
        "to": "server",
        "filter": ["**/*", "!node_modules"]
      },
      {
        "from": "../public",
        "to": "public"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["ru_RU", "en_US"],
      "language": "1049"
    }
  }
}
